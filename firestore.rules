rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin') ||
        request.auth.token.email == "alifweb@gmail.com" ||
        request.auth.token.email == "alifbrur16@gmail.com" ||
        request.auth.token.email == "alif21@gmail.com"
      );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // Quiz validation
    function isValidQuiz(data) {
      return isAuthenticated() && 
             (data.get('userId', request.auth.uid) == request.auth.uid || isAdmin());
    }

    function isResourceOwner(resourceDoc) {
      return isAuthenticated() && (
        resourceDoc == null ||
        resourceDoc.data.get('userId', request.auth.uid) == request.auth.uid ||
        resourceDoc.data.get('userId', 'anonymous') == 'anonymous' ||
        resourceDoc.data.get('userId', 'anonymous') == '' ||
        resourceDoc.data.get('userId', 'anonymous') == 'undefined' ||
        resourceDoc.data.get('userId', 'anonymous') == 'null' ||
        isAdmin()
      );
    }

    // User profiles
    match /users/{userId} {
      allow list: if isAdmin();
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Quiz questions
    match /quizzes/{quizId} {
      allow read: if isResourceOwner(resource) || isAdmin();
      allow create: if isAuthenticated() && isValidQuiz(request.resource.data);
      allow update: if isResourceOwner(resource) || isAdmin();
      allow delete: if isResourceOwner(resource) || isAdmin();
    }

    // Drafts
    match /drafts/{draftId} {
      allow read: if isResourceOwner(resource) || isAdmin();
      allow create: if isAuthenticated() && isValidQuiz(request.resource.data);
      allow update: if isResourceOwner(resource) || isAdmin();
      allow delete: if isResourceOwner(resource) || isAdmin();
    }

    // Smart Notes
    match /notes/{noteId} {
      allow read: if isResourceOwner(resource) || isAdmin();
      allow create: if isResourceOwner(request.resource) || isAdmin();
      allow update: if isResourceOwner(resource) || isAdmin();
      allow delete: if isResourceOwner(resource) || isAdmin();
    }

    // User settings
    match /settings/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if false;
    }

    // System configuration
    match /system/config {
      allow read: if true; // Everyone can see global defaults
      allow write: if isAdmin(); // Only admins can modify
    }
    
    match /system/stats {
      allow read: if true; // Everyone can read stats
      allow write: if isAuthenticated(); // Authenticated users can update stats (like incrementing user count)
    }
  }
}
