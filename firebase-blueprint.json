{
  "entities": {
    "user": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "role"]
    },
    "note": {
      "title": "Note",
      "description": "A smart formatted note generated by Gemini from raw text, JSON, or CSV formats",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "rawInput": { "type": "string" },
        "formattedContent": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "sent", "error"] },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "userId", "title", "rawInput", "formattedContent", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "User documents containing role info"
    },
    "/notes/{noteId}": {
      "schema": "note",
      "description": "Collection of smart notes generated and managed by users"
    }
  }
}
